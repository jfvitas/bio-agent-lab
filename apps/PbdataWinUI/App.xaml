<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="PbdataWinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="BrandAqua">#12BFC6</Color>
            <Color x:Key="BrandBlue">#1D4ED8</Color>
            <Color x:Key="BrandGold">#F6C453</Color>
            <Color x:Key="BrandCoral">#FB7185</Color>
            <Color x:Key="BrandInk">#0C1726</Color>

            <SolidColorBrush x:Key="BrandAquaBrush" Color="{StaticResource BrandAqua}" />
            <SolidColorBrush x:Key="BrandBlueBrush" Color="{StaticResource BrandBlue}" />
            <SolidColorBrush x:Key="BrandGoldBrush" Color="{StaticResource BrandGold}" />
            <SolidColorBrush x:Key="BrandCoralBrush" Color="{StaticResource BrandCoral}" />
            <SolidColorBrush x:Key="BrandInkBrush" Color="{StaticResource BrandInk}" />

            <x:Double x:Key="PageWidth">1160</x:Double>

            <Style x:Key="PageTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="30" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="EyebrowStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource BrandAquaBrush}" />
                <Setter Property="CharacterSpacing" Value="80" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="22" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="SectionCaptionStyle" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="LineHeight" Value="22" />
            </Style>

            <Style x:Key="BodyTextStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="LineHeight" Value="24" />
            </Style>

            <Style x:Key="CardBorderStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="Padding" Value="20" />
            </Style>

            <Style x:Key="SubtleCardBorderStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
                <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="Padding" Value="16" />
            </Style>

            <Style x:Key="PrimaryActionStyle" TargetType="Button">
                <Setter Property="Padding" Value="18,12" />
                <Setter Property="MinHeight" Value="44" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Background" Value="{StaticResource BrandAquaBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SecondaryActionStyle" TargetType="Button">
                <Setter Property="Padding" Value="16,11" />
                <Setter Property="MinHeight" Value="42" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="MetricValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="KpiValueStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
