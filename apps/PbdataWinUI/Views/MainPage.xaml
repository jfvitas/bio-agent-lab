<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PbdataWinUI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

        <NavigationView
        x:Name="ShellNav"
        CompactModeThresholdWidth="960"
        ExpandedModeThresholdWidth="1360"
        CompactPaneLength="48"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="False"
        OpenPaneLength="232"
        PaneDisplayMode="Left"
        SelectionChanged="OnSelectionChanged">
        <NavigationView.Header>
            <Grid
                MaxWidth="{StaticResource PageWidth}"
                Margin="20,12,20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="392" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="PROTEOSPHERE" />
                    <TextBlock Style="{StaticResource PageTitleStyle}" Text="Protein Intelligence Platform" />
                    <TextBlock
                        MaxWidth="700"
                        Style="{StaticResource SectionCaptionStyle}"
                        Text="{x:Bind ViewModel.DemoDisclaimer, Mode=OneWay}"
                        TextWrapping="WrapWholeWords" />
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Border Style="{StaticResource SubtleCardBorderStyle}">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Workflow progress" />
                                <TextBlock Style="{StaticResource KpiValueStyle}" Text="{x:Bind ViewModel.ProgressLabel, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource SubtleCardBorderStyle}">
                            <StackPanel Spacing="4">
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Recommended section" />
                                <TextBlock Style="{StaticResource KpiValueStyle}" Text="{x:Bind ViewModel.CurrentRecommendedPageKey, Mode=OneWay}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>

                <Border
                    Grid.Column="1"
                    Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Style="{StaticResource EyebrowStyle}" Text="NEXT WORKFLOW STEP" />
                        <TextBlock
                            FontSize="22"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.CurrentStepTitle, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{x:Bind ViewModel.ProgressLabel, Mode=OneWay}" />
                        <TextBlock
                            Style="{StaticResource BodyTextStyle}"
                            Text="{x:Bind ViewModel.CurrentStepWhy, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Click this next" />
                        <TextBlock
                            FontSize="16"
                            FontWeight="SemiBold"
                            Text="{x:Bind ViewModel.CurrentStepClick, Mode=OneWay}"
                            TextWrapping="WrapWholeWords" />
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="10">
                            <Button
                                Click="OnExecuteRecommendedStep"
                                Content="Do next step"
                                Style="{StaticResource PrimaryActionStyle}" />
                            <Button
                                Click="OnOpenRecommendedSection"
                                Content="Open section"
                                Style="{StaticResource SecondaryActionStyle}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </NavigationView.Header>

        <NavigationView.MenuItems>
            <NavigationViewItem Tag="Guide" Content="Workflow">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Map" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="Dataset" Content="Dataset">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Library" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="Model" Content="Models">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Bullets" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="Inference" Content="Inference">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Forward" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Tag="Outputs" Content="Outputs">
                <NavigationViewItem.Icon>
                    <SymbolIcon Symbol="Document" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Frame x:Name="ContentFrame" />
    </NavigationView>
</Page>
