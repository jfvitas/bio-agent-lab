<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PbdataWinUI.Views.OutputsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="{StaticResource PageWidth}"
            Margin="24,20,24,32"
            Spacing="20">
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="10">
                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="OUTPUTS" />
                    <TextBlock Style="{StaticResource PageTitleStyle}" Text="Current workspace outputs and operational artifacts" />
                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.RunSummary, Mode=OneWay}" />
                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="{x:Bind ViewModel.SelectedRunName, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.95*" />
                    <ColumnDefinition Width="1.05*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Saved artifacts" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.ArtifactSummaries, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,12"
                                        Style="{StaticResource SubtleCardBorderStyle}">
                                        <StackPanel Spacing="4">
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="SemiBold"
                                                Text="{Binding Title}" />
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Status}" />
                                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Summary}" />
                                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Path}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Workflow engine" />
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ProgressRing
                                Width="28"
                                Height="28"
                                IsActive="{x:Bind ViewModel.IsWorkflowBusy, Mode=OneWay}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.ActiveWorkflowLabel, Mode=OneWay}" />
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{x:Bind ViewModel.WorkflowStatus, Mode=OneWay}" />
                                <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.LastWorkflowCommand, Mode=OneWay}" />
                            </StackPanel>
                        </Grid>
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Recent command output" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.WorkflowConsoleLines, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Style="{StaticResource SectionCaptionStyle}"
                                        Text="{Binding}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Activity log" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ActivityLog, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Margin="0,0,0,8"
                                    Style="{StaticResource SectionCaptionStyle}"
                                    Text="{Binding}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
