<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PbdataWinUI.Views.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="{StaticResource PageWidth}"
            Margin="24,20,24,32"
            Spacing="20">
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="PLATFORM TOUR" />
                    <TextBlock Style="{StaticResource PageTitleStyle}" Text="{x:Bind ViewModel.DemoHeadline, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.WorkspaceSummary, Mode=OneWay}" />
                    <StackPanel Spacing="6">
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Workspace root" />
                        <TextBox Text="{x:Bind ViewModel.WorkspaceRootInput, Mode=TwoWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button
                                Command="{x:Bind ViewModel.ApplyWorkspaceRootCommand}"
                                Content="Apply root"
                                Style="{StaticResource SecondaryActionStyle}" />
                            <Button
                                Command="{x:Bind ViewModel.RefreshWorkspaceCommand}"
                                Content="Refresh artifacts"
                                Style="{StaticResource SecondaryActionStyle}" />
                        </StackPanel>
                    </StackPanel>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ProgressRing
                            Width="28"
                            Height="28"
                            IsActive="{x:Bind ViewModel.IsWorkflowBusy, Mode=OneWay}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Workflow status" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.ActiveWorkflowLabel, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.WorkflowStatus, Mode=OneWay}" />
                        </StackPanel>
                    </Grid>
                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.CurrentStepWhy, Mode=OneWay}" />

                    <CommandBar DefaultLabelPosition="Right">
                        <AppBarButton
                            Command="{x:Bind ViewModel.RunStatusCheckCommand}"
                            Label="Status check">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Sync" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            Command="{x:Bind ViewModel.RunDoctorCheckCommand}"
                            Label="Readiness">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Repair" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            Command="{x:Bind ViewModel.RunSmokeCheckCommand}"
                            Label="Smoke check">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Accept" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            Command="{x:Bind ViewModel.StartGuidedDemoCommand}"
                            Label="Start tour">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Play" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            Command="{x:Bind ViewModel.BuildBootstrapStoreCommand}"
                            Label="Build foundation">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Download" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            Command="{x:Bind ViewModel.RunCompleteStoryCommand}"
                            Label="Run workflow">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Forward" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            Command="{x:Bind ViewModel.ResetDemoCommand}"
                            Label="Refresh view">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Refresh" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar>
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Product workflow" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.TimelineStages, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,12"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="16">
                                        <StackPanel Spacing="6">
                                            <TextBlock
                                                Foreground="{Binding AccentBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Text="{Binding StatusLabel}" />
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="SemiBold"
                                                Text="{Binding Title}" />
                                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Summary}" />
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding PageKey}" />
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Text="{Binding ActionLabel}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="20">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recommended next action" />
                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Recommended control" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.CurrentStepClick, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="How to find it" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.CurrentStepFind, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Local-first foundation" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.BootstrapNarrative, Mode=OneWay}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.BootstrapStats, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,12"
                                            Style="{StaticResource SubtleCardBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Label}" />
                                                <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Caption}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Selected-PDB refresh" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.RefreshPlanNarrative, Mode=OneWay}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.RefreshPlanStats, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,12"
                                            Style="{StaticResource SubtleCardBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Label}" />
                                                <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Caption}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Machine readiness" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="This panel shows what this machine can execute right now before you launch a graph, training, export, or WinUI workflow step." />
                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.EnvironmentGuidance, Mode=OneWay}" TextWrapping="WrapWholeWords" />
                            <StackPanel Spacing="6">
                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Suggested install commands" />
                                <TextBox
                                    IsReadOnly="True"
                                    MinHeight="92"
                                    Text="{x:Bind ViewModel.EnvironmentFixCommands, Mode=OneWay}"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{x:Bind ViewModel.EnvironmentStats, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="0,0,0,12"
                                            Style="{StaticResource SubtleCardBorderStyle}">
                                            <StackPanel Spacing="4">
                                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Label}" />
                                                <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding Value}" />
                                                <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Caption}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Platform at a glance" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="ProteoSphere brings together local data foundation coverage, representative search breadth, leakage-aware dataset design, model-family tradeoffs, training evidence, and explainable saved-model inference." />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.MetricBars, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12" Spacing="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" Style="{StaticResource MetricLabelStyle}" Text="{Binding DisplayValue}" />
                                            </Grid>
                                            <ProgressBar Maximum="1" Minimum="0" Value="{Binding Value}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
