<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="PbdataWinUI.Views.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="{StaticResource PageWidth}"
            Margin="24,20,24,32"
            Spacing="20">
            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="14">
                    <TextBlock Style="{StaticResource EyebrowStyle}" Text="START HERE" />
                    <TextBlock Style="{StaticResource PageTitleStyle}" Text="{x:Bind ViewModel.DemoHeadline, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.CurrentStepWhy, Mode=OneWay}" />

                    <CommandBar DefaultLabelPosition="Right">
                        <AppBarButton
                            Command="{x:Bind ViewModel.StartGuidedDemoCommand}"
                            Label="Begin workflow">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Play" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            Command="{x:Bind ViewModel.RunCompleteStoryCommand}"
                            Label="Run workflow">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Forward" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                        <AppBarButton
                            Command="{x:Bind ViewModel.ResetDemoCommand}"
                            Label="Reset preview">
                            <AppBarButton.Icon>
                                <SymbolIcon Symbol="Refresh" />
                            </AppBarButton.Icon>
                        </AppBarButton>
                    </CommandBar>
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="0.9*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Guided walkthrough" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.TimelineStages, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Margin="0,0,0,12"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16"
                                        Padding="16">
                                        <StackPanel Spacing="6">
                                            <TextBlock
                                                Foreground="{Binding AccentBrush}"
                                                FontSize="12"
                                                FontWeight="SemiBold"
                                                Text="{Binding StatusLabel}" />
                                            <TextBlock
                                                FontSize="18"
                                                FontWeight="SemiBold"
                                                Text="{Binding Title}" />
                                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Summary}" />
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding PageKey}" />
                                            <TextBlock
                                                FontSize="14"
                                                FontWeight="SemiBold"
                                                Text="{Binding ActionLabel}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Spacing="20">
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="8">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="What to click next" />
                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="Recommended control" />
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="{x:Bind ViewModel.CurrentStepClick, Mode=OneWay}" />
                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="How to find it" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="{x:Bind ViewModel.CurrentStepFind, Mode=OneWay}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock Style="{StaticResource SectionTitleStyle}" Text="What this preview communicates" />
                            <TextBlock Style="{StaticResource BodyTextStyle}" Text="This shell shows the intended end-to-end product story: representative search coverage, leakage-aware dataset design, model-family tradeoffs, training curves, and saved-model inference." />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.MetricBars, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12" Spacing="6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource MetricLabelStyle}" Text="{Binding Label}" />
                                                <TextBlock Grid.Column="1" Style="{StaticResource MetricLabelStyle}" Text="{Binding DisplayValue}" />
                                            </Grid>
                                            <ProgressBar Maximum="1" Minimum="0" Value="{Binding Value}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
