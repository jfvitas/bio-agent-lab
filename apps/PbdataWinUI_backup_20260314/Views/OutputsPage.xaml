<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PbdataWinUI.Views.OutputsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PbdataWinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="{StaticResource PageWidth}"
            Margin="24,20,24,32"
            HorizontalAlignment="Center"
            Spacing="20">

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PageTitleStyle}" Text="Run Outputs" />
                <TextBlock
                    Style="{StaticResource SectionCaptionStyle}"
                    Text="Everything a polished demo should leave behind: reports, bundles, comparison artifacts, and saved-model outputs." />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="8">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="{x:Bind ViewModel.SelectedRunName, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.RunSummary, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Generated artifacts" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ArtifactSummaries, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ArtifactSummary">
                                <Border
                                    Margin="0,0,0,12"
                                    Padding="16"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="16">
                                    <StackPanel Spacing="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                            <TextBlock Grid.Column="1" Foreground="{StaticResource BrandAquaBrush}" Text="{Binding Status}" />
                                        </Grid>
                                        <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Summary}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Reference runs" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.ComparisonRuns, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:RunSummary">
                                <Border
                                    Margin="0,0,0,12"
                                    Padding="18"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{Binding AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                        <TextBlock Text="{Binding HeadlineMetric}" />
                                        <TextBlock Text="{Binding SupportMetric}" />
                                        <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Note}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
