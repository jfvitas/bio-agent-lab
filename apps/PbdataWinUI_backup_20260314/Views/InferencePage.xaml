<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PbdataWinUI.Views.InferencePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PbdataWinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="{StaticResource PageWidth}"
            Margin="24,20,24,32"
            HorizontalAlignment="Center"
            Spacing="20">

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PageTitleStyle}" Text="Inference Lab" />
                <TextBlock
                    Style="{StaticResource SectionCaptionStyle}"
                    Text="Show how a saved demo model turns a new protein context into ranked, explainable predictions." />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Inference setup" />
                        <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.InferenceNarrative, Mode=OneWay}" />
                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedRunName, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Width="280" Spacing="10">
                        <TextBlock FontWeight="SemiBold" Text="Scenario" />
                        <ComboBox
                            DisplayMemberPath="Label"
                            ItemsSource="{x:Bind ViewModel.InferenceScenarios, Mode=OneWay}"
                            SelectedValue="{x:Bind ViewModel.SelectedInferenceScenarioKey, Mode=TwoWay}"
                            SelectedValuePath="Key" />
                        <Button
                            Command="{x:Bind ViewModel.RunInferenceCommand}"
                            Content="Run Inference"
                            Style="{StaticResource PrimaryActionStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Ranked results" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Predictions, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:PredictionSummary">
                                <Border
                                    Margin="0,0,0,12"
                                    Padding="18"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="16">
                                    <StackPanel Spacing="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding PairLabel}" />
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock FontWeight="SemiBold" Text="{Binding Score}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding Confidence}" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Rationale}" />
                                        <TextBlock Foreground="{StaticResource BrandCoralBrush}" Text="{Binding RiskNote}" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
