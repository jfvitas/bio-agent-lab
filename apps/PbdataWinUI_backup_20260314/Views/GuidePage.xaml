<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PbdataWinUI.Views.GuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PbdataWinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="{StaticResource PageWidth}"
            Margin="24,20,24,32"
            HorizontalAlignment="Center"
            Spacing="20">

            <InfoBar
                IsOpen="True"
                Severity="Informational"
                Title="Demo Mode"
                Message="{x:Bind ViewModel.DemoDisclaimer, Mode=OneWay}" />

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource PageTitleStyle}" Text="Guided Demo" />
                    <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.DemoHeadline, Mode=OneWay}" />

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Command="{x:Bind ViewModel.StartGuidedDemoCommand}"
                            Content="Start guided demo"
                            Style="{StaticResource PrimaryActionStyle}" />
                        <Button
                            Grid.Column="1"
                            Command="{x:Bind ViewModel.RunCompleteStoryCommand}"
                            Content="Run complete story"
                            Style="{StaticResource SecondaryActionStyle}" />
                        <Button
                            Grid.Column="2"
                            HorizontalAlignment="Left"
                            Command="{x:Bind ViewModel.ResetDemoCommand}"
                            Content="Reset"
                            Style="{StaticResource SecondaryActionStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <TextBlock Foreground="{StaticResource BrandGoldBrush}" FontWeight="SemiBold" Text="CURRENT GUIDED STEP" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.CurrentStepTitle, Mode=OneWay}" />
                        <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.CurrentStepWhy, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock FontWeight="SemiBold" Text="What to click now" />
                        <TextBlock Text="{x:Bind ViewModel.CurrentStepClick, Mode=OneWay}" />
                        <TextBlock FontWeight="SemiBold" Text="How to find it" />
                        <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.CurrentStepFind, Mode=OneWay}" />
                        <Button
                            Content="Open recommended page"
                            Style="{StaticResource PrimaryActionStyle}"
                            Click="OpenRecommendedPage_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Pipeline walkthrough" />
                    <ItemsControl ItemsSource="{x:Bind ViewModel.TimelineStages, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:DemoTimelineStage">
                                <Border
                                    Margin="0,0,0,12"
                                    Padding="18"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{Binding AccentBrush}"
                                    BorderThickness="1"
                                    CornerRadius="16">
                                        <Grid ColumnSpacing="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                        <Border
                                            Width="14"
                                            Height="14"
                                            VerticalAlignment="Top"
                                            Background="{Binding AccentBrush}"
                                            CornerRadius="7" />
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock
                                                Foreground="{Binding AccentBrush}"
                                                FontWeight="SemiBold"
                                                Text="{Binding StatusLabel}" />
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="{Binding Title}" />
                                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Summary}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{Binding ActionLabel}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Live activity log" />
                    <ListView
                        Height="240"
                        IsItemClickEnabled="False"
                        ItemsSource="{x:Bind ViewModel.ActivityLog, Mode=OneWay}"
                        SelectionMode="None" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
