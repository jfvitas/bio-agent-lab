<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PbdataWinUI.Views.ModelStudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:PbdataWinUI.Models"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="{StaticResource PageWidth}"
            Margin="24,20,24,32"
            HorizontalAlignment="Center"
            Spacing="20">

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PageTitleStyle}" Text="Model Studio" />
                <TextBlock
                    Style="{StaticResource SectionCaptionStyle}"
                    Text="Choose a plausible architecture, see why it was recommended, and review realistic training outputs without waiting on a real cluster job." />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Model design controls" />

                    <Grid ColumnSpacing="18" RowSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Model family" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.ModelFamilies, Mode=OneWay}"
                                SelectedValue="{x:Bind ViewModel.SelectedModelFamilyKey, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Modality blend" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.Modalities, Mode=OneWay}"
                                SelectedValue="{x:Bind ViewModel.SelectedModalityKey, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Embedding strategy" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.EmbeddingStrategies, Mode=OneWay}"
                                SelectedValue="{x:Bind ViewModel.SelectedEmbeddingKey, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Run profile" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.SpeedProfiles, Mode=OneWay}"
                                SelectedValue="{x:Bind ViewModel.SelectedSpeedKey, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Command="{x:Bind ViewModel.RecommendModelCommand}"
                            Content="Recommend"
                            Style="{StaticResource SecondaryActionStyle}" />
                        <Button
                            Grid.Column="1"
                            Command="{x:Bind ViewModel.TrainModelCommand}"
                            Content="Train"
                            Style="{StaticResource PrimaryActionStyle}" />
                        <Button
                            Grid.Column="2"
                            Command="{x:Bind ViewModel.CompareRunsCommand}"
                            Content="Compare"
                            Style="{StaticResource SecondaryActionStyle}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="10">
                        <TextBlock Foreground="{StaticResource BrandAquaBrush}" FontWeight="SemiBold" Text="RECOMMENDED PATH" />
                        <TextBlock FontSize="24" FontWeight="SemiBold" Text="{x:Bind ViewModel.SelectedModelHeadline, Mode=OneWay}" />
                        <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.SelectedModelPitch, Mode=OneWay}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Architecture preview" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.ArchitectureStages, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:ArchitectureStage">
                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="14"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Foreground="{Binding AccentBrush}" FontWeight="SemiBold" Text="{Binding StepLabel}" />
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Title}" />
                                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Summary}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Training outputs" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.TrainingStats, Mode=OneWay}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:StatCard">
                                <Border
                                    Width="260"
                                    Margin="0,0,16,16"
                                    Padding="18"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    CornerRadius="16">
                                    <StackPanel Spacing="6">
                                        <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                        <TextBlock Style="{StaticResource MetricValueStyle}" Text="{Binding Value}" />
                                        <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Caption}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border
                        Padding="18"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="16">
                        <StackPanel Spacing="12">
                            <TextBlock FontWeight="SemiBold" Text="Training curve preview" />
                            <Grid Width="700" Height="240">
                                <Rectangle
                                    Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                                    StrokeThickness="1"
                                    RadiusX="14"
                                    RadiusY="14" />
                                <Polyline
                                    Margin="12"
                                    Points="{x:Bind ViewModel.TrainingCurvePoints, Mode=OneWay}"
                                    Stroke="{StaticResource BrandAquaBrush}"
                                    StrokeThickness="4" />
                                <Polyline
                                    Margin="12"
                                    Points="{x:Bind ViewModel.ValidationCurvePoints, Mode=OneWay}"
                                    Stroke="{StaticResource BrandGoldBrush}"
                                    StrokeThickness="4" />
                            </Grid>
                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.RunSummary, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Why this run works" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.MetricBars, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:MetricBar">
                                    <StackPanel Margin="0,0,0,12" Spacing="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Label}" />
                                            <TextBlock Grid.Column="1" Text="{Binding DisplayValue}" />
                                        </Grid>
                                        <ProgressBar Maximum="1" Minimum="0" Value="{Binding Value}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="12">
                        <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Recent simulated runs" />
                        <ItemsControl ItemsSource="{x:Bind ViewModel.ComparisonRuns, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:RunSummary">
                                    <Border
                                        Margin="0,0,0,10"
                                        Padding="16"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{Binding AccentBrush}"
                                        BorderThickness="1"
                                        CornerRadius="16">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                            <TextBlock Text="{Binding Family}" />
                                            <TextBlock Text="{Binding HeadlineMetric}" />
                                            <TextBlock Text="{Binding SupportMetric}" />
                                            <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{Binding Note}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
