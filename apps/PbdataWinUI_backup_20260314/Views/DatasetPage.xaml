<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="PbdataWinUI.Views.DatasetPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="{StaticResource PageWidth}"
            Margin="24,20,24,32"
            HorizontalAlignment="Center"
            Spacing="20">

            <StackPanel Spacing="4">
                <TextBlock Style="{StaticResource PageTitleStyle}" Text="Dataset Builder" />
                <TextBlock
                    Style="{StaticResource SectionCaptionStyle}"
                    Text="Shape a representative, leakage-aware training set before you ever think about training the model." />
            </StackPanel>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Current guidance" />
                    <TextBlock FontSize="20" FontWeight="SemiBold" Text="{x:Bind ViewModel.CurrentStepTitle, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.CurrentStepWhy, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Design controls" />

                    <StackPanel Spacing="12">
                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Dataset scope" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.DatasetProfiles, Mode=OneWay}"
                                SelectedValue="{x:Bind ViewModel.SelectedDatasetProfileKey, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Balancing strategy" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.BalanceStrategies, Mode=OneWay}"
                                SelectedValue="{x:Bind ViewModel.SelectedBalanceKey, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock FontWeight="SemiBold" Text="Embedding branch" />
                            <ComboBox
                                DisplayMemberPath="Label"
                                ItemsSource="{x:Bind ViewModel.EmbeddingStrategies, Mode=OneWay}"
                                SelectedValue="{x:Bind ViewModel.SelectedEmbeddingKey, Mode=TwoWay}"
                                SelectedValuePath="Key" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button
                            Command="{x:Bind ViewModel.PreviewSearchCommand}"
                            Content="Preview Search"
                            Style="{StaticResource SecondaryActionStyle}" />
                        <Button
                            Command="{x:Bind ViewModel.AssembleDatasetCommand}"
                            Content="Assemble Set"
                            Style="{StaticResource PrimaryActionStyle}" />
                        <Button
                            Command="{x:Bind ViewModel.DesignSplitCommand}"
                            Content="Design Split"
                            Style="{StaticResource SecondaryActionStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource SectionTitleStyle}" Text="Dataset story" />
                    <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.DatasetNarrative, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource SectionCaptionStyle}" Text="{x:Bind ViewModel.SplitNarrative, Mode=OneWay}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
